{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://portolan.dev/schema/corpus-manifest.schema.json",
  "title": "Portolan Test Corpus Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "label",
    "status",
    "last_reviewed",
    "purpose",
    "source_references",
    "layers",
    "targets",
    "acceptance_checks",
    "scope_exclusions"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "label": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["candidate", "active", "retired"]
    },
    "last_reviewed": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "source_references": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source_reference"
      }
    },
    "layers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/layer"
      }
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/target"
      }
    },
    "acceptance_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/acceptance_check"
      }
    },
    "scope_exclusions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "evidence_state": {
      "type": "string",
      "enum": [
        "source-visible",
        "metadata-visible",
        "runtime-visible",
        "claim-only",
        "unknown",
        "cannot_verify"
      ]
    },
    "source_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "type", "url", "evidence_state"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "official-doc",
            "official-release",
            "official-repo",
            "official-attic",
            "official-download",
            "official-issue-tracker",
            "official-wiki",
            "official-mailing-list",
            "official-ci"
          ]
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "evidence_state": {
          "$ref": "#/$defs/evidence_state"
        },
        "note": {
          "type": "string"
        }
      }
    },
    "layer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "intent", "default_evidence_state", "target_ids"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "intent": {
          "type": "string",
          "minLength": 1
        },
        "default_evidence_state": {
          "$ref": "#/$defs/evidence_state"
        },
        "target_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "kind", "lifecycle", "role", "evidence_state"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "repository",
            "release",
            "package",
            "runtime",
            "documentation",
            "binary-repository",
            "docker-image",
            "retired-project",
            "issue-tracker",
            "wiki",
            "mailing-list"
          ]
        },
        "lifecycle": {
          "type": "string",
          "enum": ["active", "incubating", "retired", "external", "internal-support"]
        },
        "role": {
          "type": "string",
          "minLength": 1
        },
        "evidence_state": {
          "$ref": "#/$defs/evidence_state"
        },
        "version": {
          "type": "string"
        },
        "repository_url": {
          "type": "string",
          "format": "uri"
        },
        "project_url": {
          "type": "string",
          "format": "uri"
        },
        "reference_url": {
          "type": "string",
          "format": "uri"
        },
        "tracker_url": {
          "type": "string",
          "format": "uri"
        },
        "wiki_url": {
          "type": "string",
          "format": "uri"
        },
        "wiki_evidence_state": {
          "$ref": "#/$defs/evidence_state"
        },
        "wiki_note": {
          "type": "string"
        },
        "docs_url": {
          "type": "string",
          "format": "uri"
        },
        "mailing_list_url": {
          "type": "string",
          "format": "uri"
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "acceptance_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "requirement"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^AC-[0-9]{3}$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "requirement": {
          "type": "string",
          "minLength": 1
        },
        "evidence_state": {
          "$ref": "#/$defs/evidence_state"
        }
      }
    }
  }
}
