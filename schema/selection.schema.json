{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://portolan.dev/schema/selection.schema.json",
  "title": "Portolan Selection",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "targets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/target"
      }
    },
    "metadata": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/input_source"
      }
    },
    "runtime": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/input_source"
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/input_source"
      }
    }
  },
  "$defs": {
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "path"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": ["repository", "service", "package", "runtime", "team", "claim", "unknown"]
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "input_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
