{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://portolan.dev/schema/evidence-graph.schema.json",
  "title": "Portolan Evidence Graph",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generated_by", "nodes", "edges"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "generated_by": {
      "type": "string",
      "minLength": 1
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    }
  },
  "$defs": {
    "evidence_state": {
      "type": "string",
      "enum": [
        "source-visible",
        "metadata-visible",
        "runtime-visible",
        "claim-only",
        "unknown",
        "cannot_verify"
      ]
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "source"],
      "properties": {
        "state": {
          "$ref": "#/$defs/evidence_state"
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "observed_at": {
          "type": "string",
          "format": "date-time"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "label", "evidence"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": ["repository", "service", "package", "runtime", "team", "claim", "unknown", "external"]
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "$ref": "#/$defs/evidence"
        }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "kind", "evidence"],
      "properties": {
        "from": {
          "type": "string",
          "minLength": 1
        },
        "to": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": ["owns", "depends-on", "exposes", "imports", "observes", "claims", "unknown", "references"]
        },
        "evidence": {
          "$ref": "#/$defs/evidence"
        }
      }
    }
  }
}
