{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://portolan.local/schemas/landscape-report.schema.json",
  "title": "Portolan Landscape Report",
  "type": "object",
  "required": ["schema_version", "sections"],
  "properties": {
    "schema_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "target_root": { "type": "string" },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "blocks": { "type": "array" },
          "items": { "type": "array" },
          "groups": { "type": "array" }
        }
      }
    }
  },
  "additionalProperties": true
}
