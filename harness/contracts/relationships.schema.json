{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "portolan-relationships",
  "title": "Portolan cross-repo relationship edge (relationships.jsonl line, spec 105)",
  "type": "object",
  "required": ["id", "type", "summary", "evidence_state", "producer", "producer_ref"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "type": {
      "enum": ["depends-on", "uses-image", "shared-dependency", "cross-repo-duplication"]
    },
    "from_repo": { "type": ["string", "null"] },
    "to_repo": { "type": ["string", "null"] },
    "repos": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Repo ids for hub-style edges (shared-dependency); binary edges use from_repo/to_repo."
    },
    "summary": { "type": "string" },
    "detail": { "type": "object" },
    "evidence_state": {
      "enum": ["source-visible", "metadata-visible", "runtime-visible", "claim-only", "unknown", "cannot_verify"]
    },
    "producer": { "type": "string" },
    "producer_ref": { "type": "string" }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "shared-dependency" } } },
      "then": { "required": ["repos"] },
      "else": { "required": ["from_repo", "to_repo"] }
    }
  ]
}
