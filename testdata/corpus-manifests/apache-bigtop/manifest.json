    },
    {
      "id": "legacy-retired-expansion",
      "label": "Retired Hadoop-era legacy projects",
      "intent": "Check that Portolan can represent historically important but retired projects without treating them as healthy current surfaces.",
      "default_evidence_state": "metadata-visible",
      "target_ids": [
        "apache-oozie",
        "apache-sqoop"
      ]
    },
    {
      "id": "runtime-black-box",
      "label": "Package and runtime surfaces",
      "intent": "Prepare black-box testing against Bigtop binary repositories, Docker images, CI, and smoke-test outputs without making network access a default scan behavior.",
      "default_evidence_state": "metadata-visible",
      "target_ids": [
        "bigtop-binary-repos",
        "bigtop-docker-images",
        "bigtop-ci"
      ]
    }
