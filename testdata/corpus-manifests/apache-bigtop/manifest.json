  "acceptance_checks": [
    {
      "id": "AC-001",
      "label": "Release BOM coverage",
      "requirement": "The corpus must preserve the Bigtop 3.5.0 component set and versions from the official release BOM.",
      "evidence_state": "metadata-visible"
    },
    {
      "id": "AC-002",
      "label": "Runtime dependency coverage",
      "requirement": "The corpus must include dependency edges derived from the support matrix for Hadoop, HBase, Hive, Kafka, Livy, Phoenix, Spark, Tez, Zeppelin, and ZooKeeper.",
      "evidence_state": "metadata-visible"
    },
    {
      "id": "AC-003",
      "label": "Legacy lifecycle coverage",
      "requirement": "The corpus must include retired Hadoop-era projects and keep retirement status separate from source repository visibility.",
      "evidence_state": "metadata-visible"
    },
    {
      "id": "AC-004",
      "label": "Evidence state coverage",
      "requirement": "Fixture generation from this corpus must exercise source-visible, metadata-visible, claim-only, unknown, and cannot_verify states before it is used as an acceptance corpus.",
      "evidence_state": "cannot_verify"
    },
    {
      "id": "AC-005",
      "label": "No default network scan",
      "requirement": "A normal Portolan scan must consume a prepared local selection or fixture derived from the corpus and must not clone repositories or query upstream services by default.",
      "evidence_state": "claim-only"
    },
    {
      "id": "AC-006",
      "label": "Operator assembly acceptance",
      "requirement": "The corpus must support an end-to-end evaluation of Cursor with Composer 2.5 / Kimi 2.6 using Portolan artifacts, while keeping agent/model conclusions lower-authority than source, metadata, runtime, or explicit claim inputs.",
      "evidence_state": "claim-only"
    }
  ],
  "scope_exclusions": [
    "Do not benchmark big-data runtime performance in Portolan.",
    "Do not reimplement Bigtop packaging, smoke tests, Docker recipes, or CI.",
    "Do not treat upstream CI status as proof that Portolan verified a fact.",
    "Do not include proprietary Hadoop distributions in the initial corpus."
  ]
}
