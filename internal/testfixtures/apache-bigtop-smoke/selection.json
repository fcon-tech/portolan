{
  "schema_version": "0.1.0",
  "targets": [
    {
      "id": "apache-bigtop-repo",
      "kind": "repository",
      "path": "repo"
    },
    {
      "id": "apache-oozie-source",
      "kind": "repository",
      "path": "missing-oozie-repo"
    }
  ],
  "claims": [
    {
      "id": "bigtop-smoke-claims",
      "path": "claims/bigtop-gaps.json"
    }
  ],
  "black_boxes": [
    {
      "id": "apache-bigtop",
      "kind": "service",
      "label": "Apache Bigtop",
      "metadata": [
        {
          "id": "bigtop-root-metadata",
          "path": "metadata/bigtop-root.json"
        }
      ],
      "runtime": [
        {
          "id": "bigtop-root-runtime",
          "path": "runtime/bigtop-root.json"
        }
      ],
      "expected": [
        "owner",
        "dependencies",
        "runtime-endpoints"
      ]
    },
    {
      "id": "apache-oozie",
      "kind": "service",
      "label": "Apache Oozie",
      "metadata": [
        {
          "id": "oozie-retired-metadata",
          "path": "metadata/missing-oozie.json"
        }
      ],
      "expected": [
        "owner",
        "dependencies",
        "runtime-endpoints"
      ]
    }
  ]
}
